  "scripts": {
    "storybook": "storybook dev -p 9009",
    "build-storybook": "SET NODE_ENV=development&&storybook build",
    "build-fe": "SET NODE_ENV=production&&webpack --mode production",
    "build-fe-dev": "SET NODE_ENV=development&&webpack --mode development",
    "build-fe-deploy": "export NODE_ENV=production&&webpack --mode production",
    "watch-fe": "SET NODE_ENV=development&&webpack --mode development -w",
