{
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "AzureKeyVault": {
    "GiuruIdentityServer4Certificate": "#{AzureKeyVault--GiuruIdentityServer4Certificate}#",
    "ClientId": "#{AzureKeyVault--ClientId}#",
    "ClientSecret": "#{AzureKeyVault--ClientSecret}#"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*"
}
