{
  "ServerSideRenderingEndpoint": "http://react-ssr-web-service:3000",
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "ConnectionStrings": {
    "DatabaseContext": "#{ConnectionStrings--DatabaseContext}#"
  },
  "ServicesEndpoints": {
    "PortalEndpoint": "https://localhost:44381"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*"
}
