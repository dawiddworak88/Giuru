{
  "ServerSideRenderingEndpoint": "http://react-ssr-web-service:3000",
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "ConnectionStrings": {
    "DatabaseContext": "#{ConnectionStrings--DatabaseContext}#"
  },
  "ServicesEndpoints": {
    "AccountEndpoint": "https://localhost:44325",
    "Api": {
      "Host": "https://localhost:44383",
      "Endpoints": {
        "OrderValidation": "/api/v1.0/order/validation",
        "Client": "/api/v1.0/client",
        "Clients": "/api/v1.0/clients",
        "Product": "/api/v1.0/product",
        "Products": "/api/v1.0/products",
        "Schema": "/api/v1.0/schema",
        "SchemaByEntityType": "/api/v1.0/schema/entitytype"
      }
    }
  },
  "Seeds": {
    "Accounts": {
      "Admin": {
        "FirstName": "#{Seeds--Accounts--Admin--FirstName}#",
        "LastName": "#{Seeds--Accounts--Admin--LastName}#",
        "Email": "#{Seeds--Accounts--Admin--Email}#",
        "PasswordHash": "#{Seeds--Accounts--Admin--PasswordHash}#",
        "SecurityStamp": "#{Seeds--Accounts--Admin--SecurityStamp}#"
      },
      "Seller": {
        "FirstName": "#{Seeds--Accounts--Seller--FirstName}#",
        "LastName": "#{Seeds--Accounts--Seller--LastName}#",
        "Email": "#{Seeds--Accounts--Seller--Email}#",
        "PasswordHash": "#{Seeds--Accounts--Seller--PasswordHash}#",
        "SecurityStamp": "#{Seeds--Accounts--Seller--SecurityStamp}#",
        "Key": "#{Seeds--Accounts--Seller--Key}#",
        "Host": "#{Seeds--Accounts--Seller--Host}#",
        "DatabaseConnectionString": "#{Seeds--Accounts--Seller--DatabaseConnectionString}#",
        "QueueConnectionString": "#{Seeds--Accounts--Seller--QueueConnectionString}#",
        "StorageConnectionString": "#{Seeds--Accounts--Seller--StorageConnectionString}#"
      }
    }
  },
  "Authentication": {
    "AuthenticationScheme": "Cookies",
    "ChallengeScheme": "oidc",
    "Authority": "https://localhost:44325",
    "ClientId": "#{Authentication--ClientId}#",
    "ClientSecret": "#{Authentication--ClientSecret}#",
    "ResponseType": "code"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*"
}
