{
  "ServerSideRenderingEndpoint": "http://react-ssr-web-service:3000",
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "ConnectionStrings": {
    "DatabaseContext": "#{ConnectionStrings--DatabaseContext}#"
  },
  "ServicesEndpoints": {
    "AccountEndpoint": "https://localhost:44325",
    "ClientApi": {
      "Host": "https://localhost:44383",
      "Endpoints": {
        "Client": "/api/v1.0/client"
      }
    }
  },
  "Seeds": {
    "Accounts": {
      "Admin": {
        "FirstName": "#{Seeds--Accounts--Admin--FirstName}#",
        "LastName": "#{Seeds--Accounts--Admin--LastName}#",
        "Email": "#{Seeds--Accounts--Admin--Email}#",
        "PasswordHash": "#{Seeds--Accounts--Admin--PasswordHash}#",
        "SecurityStamp": "#{Seeds--Accounts--Admin--SecurityStamp}#"
      },
      "Tenant": {
        "FirstName": "#{Seeds--Accounts--Tenant--FirstName}#",
        "LastName": "#{Seeds--Accounts--Tenant--LastName}#",
        "Email": "#{Seeds--Accounts--Tenant--Email}#",
        "PasswordHash": "#{Seeds--Accounts--Tenant--PasswordHash}#",
        "SecurityStamp": "#{Seeds--Accounts--Tenant--SecurityStamp}#",
        "Key": "#{Seeds--Accounts--Tenant--Key}#",
        "Host": "#{Seeds--Accounts--Tenant--Host}#",
        "DatabaseConnectionString": "#{Seeds--Accounts--Tenant--DatabaseConnectionString}#",
        "QueueConnectionString": "#{Seeds--Accounts--Tenant--QueueConnectionString}#",
        "StorageConnectionString": "#{Seeds--Accounts--Tenant--StorageConnectionString}#"
      }
    }
  },
  "Authentication": {
    "AuthenticationScheme": "Cookies",
    "ChallengeScheme": "oidc",
    "Authority": "https://localhost:44325",
    "ClientId": "#{Authentication--ClientId}#",
    "ClientSecret": "#{Authentication--ClientSecret}#",
    "ResponseType": "code"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
