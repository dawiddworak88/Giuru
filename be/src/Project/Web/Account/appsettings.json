{
  "ServerSideRenderingEndpoint": "http://react-ssr-web-service:3000",
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "ConnectionStrings": {
    "DatabaseContext": "#{ConnectionStrings--DatabaseContext}#"
  },
  "Account": {
    "Clients": [
      {
        "ClientId": "#{Authentication--ClientId}#",
        "ClientSecret": "#{Authentication--ClientSecret}#",
        "Host": "localhost:44381",
        "SignInOidc": "/signin-oidc",
        "SignOutCallbackOidc": "/signout-callback-oidc"
      }
    ],
    "AzureAd": {
      "Authority": "https://login.microsoftonline.com/common",
      "ClientId": "1",
      "CallbackPath": "/signin-oidc"
    }
  },
  "AzureKeyVault": {
    "GiuruIdentityServer4Certificate": "#{AzureKeyVault--GiuruIdentityServer4Certificate}#",
    "ClientId": "#{AzureKeyVault--ClientId}#",
    "ClientSecret": "#{AzureKeyVault--ClientSecret}#"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Verbose",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*"
}
