{
  "ServerSideRenderingEndpoint": "http://react-ssr-web-service:3000",
  "Localization": {
    "DefaultRequestCulture": "pl",
    "SupportedCultures": [
      "en",
      "de",
      "pl"
    ]
  },
  "ConnectionStrings": {
    "DatabaseContext": "#{ConnectionStrings--DatabaseContext}#"
  },
  "Account": {
    "Clients": [
      {
        "ClientId": "#{Authentication--ClientId}#",
        "ClientSecret": "#{Authentication--ClientSecret}#",
        "Host": "localhost:44381",
        "SignInOidc": "/signin-oidc",
        "SignOutCallbackOidc": "/signout-callback-oidc"
      }
    ],
    "AzureAd": {
      "Authority": "https://login.microsoftonline.com/common",
      "ClientId": "1",
      "CallbackPath": "/signin-oidc"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
